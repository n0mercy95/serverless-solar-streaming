{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://solar-streaming/schemas/bq_schema.json",
  "title": "BigQuery Table Schemas",
  "description": "Esquemas de las tablas de destino en BigQuery para telemetría validada y Dead Letter Queue.",
  "version": "1.0.0",
  "tables": {
    "telemetry_validated": {
      "description": "Tabla principal con métricas agregadas y validadas por ventana temporal de 15 minutos.",
      "fields": [
        {"name": "event_id", "type": "STRING", "mode": "REQUIRED", "description": "UUID del evento agregado"},
        {"name": "plant_id", "type": "STRING", "mode": "REQUIRED", "description": "Identificador de la planta"},
        {"name": "window_start", "type": "TIMESTAMP", "mode": "REQUIRED", "description": "Inicio de la ventana temporal"},
        {"name": "window_end", "type": "TIMESTAMP", "mode": "REQUIRED", "description": "Fin de la ventana temporal"},
        {"name": "avg_ghi", "type": "FLOAT64", "mode": "REQUIRED", "description": "Promedio de irradiancia GHI en la ventana (W/m²)"},
        {"name": "avg_power_mw", "type": "FLOAT64", "mode": "REQUIRED", "description": "Potencia promedio en la ventana (MW)"},
        {"name": "max_power_mw", "type": "FLOAT64", "mode": "REQUIRED", "description": "Potencia máxima en la ventana (MW)"},
        {"name": "min_power_mw", "type": "FLOAT64", "mode": "REQUIRED", "description": "Potencia mínima en la ventana (MW)"},
        {"name": "avg_module_temp_c", "type": "FLOAT64", "mode": "REQUIRED", "description": "Temperatura promedio del módulo (°C)"},
        {"name": "reading_count", "type": "INT64", "mode": "REQUIRED", "description": "Cantidad de lecturas en la ventana"},
        {"name": "predicted_power_mw", "type": "FLOAT64", "mode": "NULLABLE", "description": "Predicción del modelo ML (MW)"},
        {"name": "anomaly_type", "type": "STRING", "mode": "REQUIRED", "description": "Tipo de anomalía detectada"},
        {"name": "anomaly_score", "type": "FLOAT64", "mode": "REQUIRED", "description": "Score de confianza de la anomalía (0-1)"},
        {"name": "ingestion_timestamp", "type": "TIMESTAMP", "mode": "REQUIRED", "description": "Marca temporal de escritura a BQ"}
      ],
      "time_partitioning": {
        "type": "DAY",
        "field": "window_start"
      },
      "clustering_fields": ["plant_id", "anomaly_type"]
    },
    "dead_letter_queue": {
      "description": "Tabla DLQ para registros que fallaron en cualquier etapa del pipeline. Campos estandarizados obligatorios según el PRD.",
      "fields": [
        {"name": "event_id", "type": "STRING", "mode": "REQUIRED", "description": "UUID del registro DLQ"},
        {"name": "original_payload", "type": "STRING", "mode": "REQUIRED", "description": "JSON original tal como llegó al pipeline"},
        {"name": "error_message", "type": "STRING", "mode": "REQUIRED", "description": "Descripción del error capturado"},
        {"name": "failure_timestamp", "type": "TIMESTAMP", "mode": "REQUIRED", "description": "Momento exacto de la falla"},
        {"name": "failed_step", "type": "STRING", "mode": "REQUIRED", "description": "Nombre de la transformación/DoFn que falló"}
      ],
      "time_partitioning": {
        "type": "DAY",
        "field": "failure_timestamp"
      }
    }
  }
}
