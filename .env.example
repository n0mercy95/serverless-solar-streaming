# ============================================================
# Google Cloud Platform — Configuración del Proyecto
# ============================================================
GCP_PROJECT_ID=tu-proyecto-gcp-id
GCP_REGION=us-central1

# ============================================================
# Pub/Sub — Ingesta de Telemetría IoT
# ============================================================
PUBSUB_TOPIC=solar-telemetry-ingest
PUBSUB_SUBSCRIPTION=solar-telemetry-sub
PUBSUB_DLQ_TOPIC=solar-telemetry-dlq

# ============================================================
# BigQuery — Almacenamiento Analítico
# ============================================================
BQ_DATASET=solar_streaming
BQ_TABLE_TELEMETRY=telemetry_validated
BQ_TABLE_DLQ=dead_letter_queue

# ============================================================
# Dataflow — Runner de Apache Beam
# ============================================================
DATAFLOW_JOB_NAME=solar-streaming-pipeline
DATAFLOW_TEMP_LOCATION=gs://tu-bucket/dataflow/temp
DATAFLOW_STAGING_LOCATION=gs://tu-bucket/dataflow/staging
DATAFLOW_MAX_WORKERS=5
DATAFLOW_MACHINE_TYPE=n1-standard-2

# ============================================================
# Emulador Local (Para desarrollo sin GCP)
# ============================================================
PUBSUB_EMULATOR_HOST=localhost:8085

# ============================================================
# Simulador — Fase 1
# ============================================================
SIMULATOR_RATE_LIMIT=100
SIMULATOR_BATCH_SIZE=50
SIMULATOR_DELAY_MS=200

# ============================================================
# Logging
# ============================================================
LOG_LEVEL=INFO
